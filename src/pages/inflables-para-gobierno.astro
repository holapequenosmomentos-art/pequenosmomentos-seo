---
import BaseLayout from "../../layouts/BaseLayout.astro";
import B2BHero from "../../components/shared/B2BHero.astro";

const whatsappUrl = "https://wa.me/525539385685?text=Hola%2C%20me%20interesan%20inflables%20para%20evento%20de%20gobierno.%20%C2%BFPodr%C3%ADan%20darme%20informaci%C3%B3n%3F";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cumplen con los requisitos de seguridad para eventos gubernamentales?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, todos nuestros equipos cuentan con certificación de seguridad, seguro de responsabilidad civil vigente y cumplen con las normativas aplicables para eventos públicos y gubernamentales.",
      },
    },
    {
      "@type": "Question",
      name: "¿Pueden emitir facturas fiscales para instituciones públicas?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, emitimos CFDI con todos los requisitos fiscales para dependencias gubernamentales, municipios e instituciones públicas. Proceso de facturación sencillo y rápido.",
      },
    },
    {
      "@type": "Question",
      name: "¿Trabajan con municipios y dependencias estatales?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, tenemos experiencia trabajando con ayuntamientos, gobiernos estatales, instancias de bienestar y desarrollo social. Conocemos los procesos de contratación pública.",
      },
    },
    {
      "@type": "Question",
      name: "¿Ofrecen paquetes para programas sociales?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, diseñamos paquetes especiales para programas de bienestar social, jornadas de integración familiar, eventos culturales y deportivas organizadas por dependencias gubernamentales.",
      },
    },
  ],
};
---

<BaseLayout
  title="Inflables para Gobierno | Renta de Juegos Inflables para Dependencias y Ayuntamientos en CDMX y Estado de México"
  description="Inflables para eventos gubernamentales, programas sociales y actividades municipales. Servicio profesional con facturación fiscal para entidades públicas en CDMX y Estado de México."
  ogImage="/og-gobierno.jpg"
  schema={faqSchema}
  breadcrumbs={[{ name: "Inflables para Gobierno", href: "/inflables-para-gobierno" }]}
>
  <B2BHero
    eyebrow="Inflables para Gobierno"
    title="Juegos inflables para"
    titleHighlight="programas sociales"
    description="Soluciones profesionales en inflables para dependencias gubernamentales, municipios e instituciones públicas. Experiencia comprobable y facturación fiscal para tu comodidad."
    badges={[
      { icon: "🏛️", label: "Entidades gubernamentales" },
      { icon: "📄", label: "Facturación CFDI" },
      { icon: "🛡️", label: "Seguro vigente" },
      { icon: "📋", label: "Documentación completa" },
    ]}
    primaryCta={{ label: "Ver catálogo", href: "/renta-de-inflables" }}
    whatsappUrl={whatsappUrl}
  />

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          ¿Por qué elegirnos para eventos gubernamentales?
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Entendemos las necesidades específicas del sector público y ofrecemos un servicio profesional que cumple con todos los requisitos.
        </p>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Facturación CFDI</h3>
          <p class="text-muted text-sm leading-relaxed">Emitimos facturas fiscales que cumplen con los requisitos de la autoridad para que tu comprobante sea válido.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Seguro de responsabilidad civil</h3>
          <p class="text-muted text-sm leading-relaxed">Cobertura vigente para tu tranquilidad y la protección de los participantes en todo momento.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Personal certificado</h3>
          <p class="text-muted text-sm leading-relaxed">Operadores capacitados que supervisan la correcta operación de los equipos durante todo el evento.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Metodos de pago flexibles</h3>
          <p class="text-muted text-sm leading-relaxed">Aceptamos transferencia, cheque y tarjeta para tu comodidad en el proceso de pago.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Cobertura regional</h3>
          <p class="text-muted text-sm leading-relaxed">Damos servicio en toda la zona metropolitana y municipios cercanos del Estado de México.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Documentación completa</h3>
          <p class="text-muted text-sm leading-relaxed">Proporcionamos tutti la documentación необходимая para tua convocatoria o proceso de contratación.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-surface border-y border-border">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          Eventos gubernamentales más comunes
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Hemos participado en todo tipo de eventos organizados por entidades públicas.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎪</div>
          <h3 class="font-display font-bold text-text mb-1">Ferias comunitarias</h3>
          <p class="text-muted text-sm">Eventos de gobierno que reunen a miles de familias.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🏥</div>
          <h3 class="font-display font-bold text-text mb-1">Programas de bienestar</h3>
          <p class="text-muted text-sm">Jornadas de salud y integración familiar.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎭</div>
          <h3 class="font-display font-bold text-text mb-1">Festivales culturales</h3>
          <p class="text-muted text-sm">Eventos artísticos y culturales con actividades infantiles.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">⚽</div>
          <h3 class="font-display font-bold text-text mb-1">Torneos deportivos</h3>
          <p class="text-muted text-sm">Competencias deportivas con áreas infantiles.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-5 md:px-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-extrabold text-white mb-4">
        ¿Planning un evento para tu dependencia?
      </h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">
        Contáctanos y recibe una cotización personalizada con facturación CFDI. Conocemos los procesos de contratación pública.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.4)] hover:-translate-y-px transition-all duration-200"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        Solicitar cotización oficial
      </a>
    </div>
  </section>
</BaseLayout>