---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  item: CollectionEntry<"venta">;
}

const { item } = Astro.props;
const d = item.data;
const href = `/venta-de-inflables/${item.id}`;
---

<li>
  <a
    href={href}
    class="group flex flex-col h-full bg-white rounded-2xl overflow-hidden border border-border shadow-[0_2px_16px_rgba(155,93,229,0.07)] hover:shadow-[0_8px_32px_rgba(155,93,229,0.15)] hover:-translate-y-1 transition-all duration-200"
  >
    <div class="relative overflow-hidden h-48">
      <Image
        src={d.imageBanner}
        alt={d.titulo}
        width="400"
        height="300"
        loading="lazy"
        class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300"
      />
    </div>

    <div class="flex flex-col flex-1 p-4">
      <h3 class="font-display font-bold text-text text-sm leading-snug mb-2 group-hover:text-primary transition-colors">
        {d.titulo}
      </h3>

      <div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-border">
        <span class="inline-flex items-center gap-1 bg-primary/10 text-primary text-[11px] font-semibold px-2 py-1 rounded-full">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <path d="M3 9h18M9 21V9" />
          </svg>
          Medidas: {d.dimensiones.largo}×{d.dimensiones.ancho}×{d.dimensiones.alto} m
        </span>

        <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 text-[11px] font-semibold px-2 py-1 rounded-full max-w-full truncate">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l9 4.5v9L12 20l-9-4.5v-9z" />
            <path d="M12 2v18M3 6.5l9 4.5 9-4.5" />
          </svg>
          <span class="truncate">Material: {d.material}</span>
        </span>
      </div>

      <div class="mt-3 flex items-center gap-1 text-primary text-[13px] font-display font-bold">
        Ver especificaciones
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </a>
</li>