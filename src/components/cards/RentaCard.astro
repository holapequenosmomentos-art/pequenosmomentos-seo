---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  item: CollectionEntry<"renta">;
  badgeColor: string;
  accentColor: string;
}

const { item, badgeColor, accentColor } = Astro.props;
const d = item.data;
const href = `/renta-de-inflables/${item.id}`;
---

<li>
  <a
    href={href}
    class="group flex flex-col h-full bg-white rounded-2xl overflow-hidden border border-border shadow-[0_2px_16px_rgba(155,93,229,0.07)] hover:shadow-[0_8px_32px_rgba(155,93,229,0.15)] hover:-translate-y-1 transition-all duration-200"
  >
    <div class="relative overflow-hidden h-48 group/media">
      {d.imageBanner ? (
        <>
          <Image
            src={d.imageBanner}
            alt={d.shortTitle}
            width="400"
            height="300"
            loading="lazy"
            class:list={[
              "w-full h-full object-cover object-center transition-transform duration-300",
              d.video ? "group-hover/media:opacity-0" : "group-hover:scale-105",
            ]}
          />
          {d.video && (
            <video
              src={d.video}
              muted
              loop
              playsinline
              preload="none"
              class="absolute inset-0 w-full h-full object-cover object-center opacity-0 group-hover/media:opacity-100 transition-opacity duration-300 pointer-events-none"
            />
          )}
        </>
      ) : d.video ? (
        <video
          src={d.video}
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
          data-video-only
        />
      ) : (
        <div class="w-full h-full bg-surface flex items-center justify-center">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-border)" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="M21 15l-5-5L5 21" />
          </svg>
        </div>
      )}

      <div class="absolute top-3 left-3">
        <span class:list={["inline-block px-2.5 py-1 rounded-full text-[11px] font-bold font-display", badgeColor]}>
          {d.categoria}
        </span>
      </div>

      {d.video && (
        <div class="absolute bottom-2 right-2 flex items-center gap-1 px-2 py-1 rounded-full bg-black/55 text-white text-[10px] font-display font-semibold group-hover/media:opacity-0 transition-opacity duration-200 pointer-events-none">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
          Pasa el mouse para ver el video
        </div>
      )}
    </div>

    <div class="flex flex-col flex-1 p-4">
      <h3 class="font-display font-bold text-text text-sm leading-snug mb-2 group-hover:text-primary transition-colors">
        {d.shortTitle}
      </h3>
      <p class="text-[12px] text-muted leading-snug line-clamp-2 mb-3">
        {d.description}
      </p>

      <div class="mt-auto pt-1">
        <span
          class:list={[
            "inline-flex items-center justify-center gap-1.5 w-full px-3 py-2.5 rounded-xl text-[13px] font-display font-bold text-white transition-all duration-200",
            accentColor,
            "group-hover:shadow-md group-hover:-translate-y-px",
          ]}
        >
          Ver detalles y cotizar
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>
  </a>
</li>

  <script>
    document
      .querySelectorAll<HTMLDivElement>(".group\\/media")
      .forEach((wrapper) => {
        const video = wrapper.querySelector("video");
        if (!video) return;

        if (video.dataset.videoOnly !== undefined) {
          const showFirstFrame = () => {
            video.currentTime = 0.1;
          };
          if (video.readyState >= 1) {
            showFirstFrame();
          } else {
            video.addEventListener("loadedmetadata", showFirstFrame, {
              once: true,
            });
          }
        }

        wrapper.addEventListener("mouseenter", () => {
          video.currentTime = 0;
          video.play().catch(() => {});
        });

        wrapper.addEventListener("mouseleave", () => {
          video.pause();
          if (video.dataset.videoOnly !== undefined) {
            video.currentTime = 0.1;
          }
        });
      });
  </script>