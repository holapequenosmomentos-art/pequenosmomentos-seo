---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
  breadcrumbs?: Array<{ name: string; href: string }>;
}

const {
  title,
  description,
  canonical,
  ogImage = "/og-default.jpg",
  schema,
  breadcrumbs,
} = Astro.props;

const siteUrl   = "https://pequenosmomentos.mx";
const siteName  = "Pequeños Momentos";
const canonicalUrl = canonical ?? Astro.url.href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  description: "Fabricante y proveedor de inflables comerciales para renta y venta en CDMX y Estado de México. Especialistas en soluciones B2B para empresas, escuelas y gobierno.",
  telephone: "+525539385685",
  email: "hola.pequenosmomentos@gmail.com",
  image: `${siteUrl}/logo-sf.png`,
  sameAs: [
    "https://www.instagram.com/pequenosmomentos.mx/",
    "https://www.facebook.com/pequenosmomentos.mx",
    "https://www.tiktok.com/@pequenosmomentos.mx",
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: "Nicolás Romero",
    addressLocality: "Nicolás Romero",
    addressRegion: "Estado de México",
    postalCode: "56600",
    addressCountry: "MX",
  },
  geo: {
    "@type": "Geo",
    latitude: 19.6414,
    longitude: -99.3014,
  },
  priceRange: "$$",
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "10:00", closes: "18:30" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Saturday"], opens: "09:00", closes: "14:00" },
  ],
  areaServed: [
    { "@type": "State", name: "Estado de México" },
    { "@type": "City", name: "Ciudad de México" },
    { "@type": "City", name: "Toluca" },
    { "@type": "City", name: "Naucalpan de Juárez" },
    { "@type": "City", name: "Tlalnepantla de Baz" },
    { "@type": "City", name: "Ecatepec de Morelos" },
    { "@type": "City", name: "Cuautitlán" },
    { "@type": "City", name: "Atizapán de Zaragoza" },
    { "@type": "City", name: "Metepec" },
    { "@type": "City", name: "Nezahualcóyotl" },
    { "@type": "City", name: "Tultitlán" },
    { "@type": "City", name: "Coacalco de Berriozábal" },
    { "@type": "City", name: "Cuautitlán Izcalli" },
    { "@type": "City", name: "Chalco" },
    { "@type": "City", name: "Texcoco" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Renta y Venta de Inflables",
    itemListElement: [
      { "@type": "Offer", name: "Renta de inflables", url: `${siteUrl}/renta-de-inflables` },
      { "@type": "Offer", name: "Venta de inflables", url: `${siteUrl}/venta-de-inflables` },
    ],
  },
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: siteName,
  image: `${siteUrl}${ogImage}`,
  priceRange: "$$",
  servesCuisine: "Renta y venta de inflables",
  address: { "@type": "PostalAddress", addressLocality: "Nicolás Romero", addressRegion: "Estado de México", addressCountry: "MX" },
};

const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.name,
    item: `${siteUrl}${crumb.href}`,
  })),
} : null;
---

<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#9B5DE5" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<meta property="og:type"        content="website" />
<meta property="og:site_name"   content={siteName} />
<meta property="og:url"         content={canonicalUrl} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={`${siteUrl}${ogImage}`} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale"      content="es_MX" />

<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}