---
const redes = [
  {
    href: "https://www.tiktok.com/@pequenosmomentos.mx",
    label: "TikTok",
    bg: "bg-text",
    fg: "text-white",
    path: `<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.77a4.85 4.85 0 0 1-1.01-.08z"/>`,
  },
  {
    href: "https://www.facebook.com/pequenosmomentos.mx",
    label: "Facebook",
    bg: "bg-[#1877F2]",
    fg: "text-white",
    path: `<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>`,
  },
  {
    href: "https://www.youtube.com/@Peque%C3%B1osMomentos-v8e",
    label: "YouTube",
    bg: "bg-[#FF0000]",
    fg: "text-white",
    path: `<path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.5 15.5v-7l6 3.5z"/>`,
  },
  {
    href: "https://www.instagram.com/pequenosmomentos.mx/",
    label: "Instagram",
    bg: "bg-[#E1306C]",
    fg: "text-white",
    path: `<rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="17.3" cy="6.7" r="0.9" fill="currentColor" stroke="none"/>`,
  },
];
---

<ul class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-16">
  <!-- Contacto -->
  <li class="bg-surface border border-border rounded-2xl p-6">
    <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-cta-dk"
        aria-hidden="true"
        ><path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
        ></path></svg
      >
      Contacto
    </p>
    <div class="flex flex-col gap-4 text-sm">
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">
          Horarios
        </p>
        <p class="text-muted leading-relaxed">
          Lun a Vie: 10:00am – 6:30pm<br />Sáb: 9:00am – 2:00pm
        </p>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">Email</p>
        <a
          href="mailto:hola.pequenosmomentos@gmail.com"
          class="text-muted hover:text-primary transition-colors break-all"
        >
          hola.pequenosmomentos@gmail.com
        </a>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">
          Teléfono
        </p>
        <a
          href="tel:+525539385685"
          class="text-muted hover:text-primary transition-colors"
          >55 3938 5685</a
        >
      </div>
    </div>
  </li>

  <!-- Servicio -->
  <li class="bg-surface border border-border rounded-2xl p-6">
    <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-primary"
        aria-hidden="true"
        ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path><circle
          cx="12"
          cy="10"
          r="3"></circle></svg
      >
      Servicio
    </p>
    <div class="flex flex-col gap-4 text-sm">
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">
          Cobertura
        </p>
        <p class="text-muted leading-relaxed">CDMX y Estado de México</p>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">
          Especialidad
        </p>
        <p class="text-muted leading-relaxed">Eventos infantiles únicos</p>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">
          Compromiso
        </p>
        <p class="text-muted leading-relaxed">Momentos inolvidables</p>
      </div>
    </div>
  </li>

  <!-- Síguenos -->
  <li class="bg-surface border border-border rounded-2xl p-6">
    <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-cta"
        aria-hidden="true"
        ><path
          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
        ></path></svg
      >
      Síguenos
    </p>
    <p class="text-sm text-muted leading-relaxed mb-5">
      ¡Mira nuestros eventos en acción!
    </p>
    <div class="flex gap-2.5 mb-4">
      {
        redes.map(({ href, label, bg, fg, path }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class:list={[
              "flex items-center justify-center w-10 h-10 rounded-full transition-transform duration-150 hover:-translate-y-0.5",
              bg,
              fg,
            ]}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              set:html={path}
            />
          </a>
        ))
      }
    </div>
    <p
      class="flex items-center gap-1.5 text-[12px] text-light bg-white rounded-lg px-3 py-2 border border-border"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle
          cx="8.5"
          cy="8.5"
          r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg
      >
      Contenido divertido y tips para fiestas
    </p>
  </li>
</ul>
