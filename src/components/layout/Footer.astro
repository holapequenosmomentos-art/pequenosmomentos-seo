---
import { Image } from "astro:assets";
import CoverageStrip from "../footer/CoverageStrip.astro";
import InfoCards from "../footer/InfoCards.astro";
import PaymentMethods from "../footer/PaymentMethods.astro";
---

<footer class="mt-auto bg-linear-to-br from-primary/5 via-surface to-cta/5">
  <div class="max-w-7xl mx-auto px-5 md:px-10 py-16">
    <!-- Encabezado de marca -->
    <div class="flex flex-col items-center text-center mb-12">
      <Image
        src="/logo-sf.png"
        alt="Pequeños Momentos"
        width="140"
        height="40"
        class="h-20 w-20 mb-3"
      />

      <div>
        <p class="text-muted max-w-100 mx-auto">
          Creando recuerdos mágicos e inolvidables para los más pequeños
        </p>
      </div>
    </div>

    <InfoCards />
    <PaymentMethods />
  </div>

  <CoverageStrip />

  <!-- Pie -->
  <div class="bg-white border-t border-border py-4">
    <div
      class="max-w-300 mx-auto px-5 md:px-10 flex flex-wrap items-center justify-between gap-3"
    >
      <p class="flex items-center gap-1.5 text-[13px] text-light">
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path
            d="M22 4 12 14.01l-3-3"></path></svg
        >
        {new Date().getFullYear()} Pequeños Momentos. Todos los derechos reservados.
      </p>
<p class="flex items-center gap-1.5 text-[13px] text-light">
  Hecho con amor para familias mexicanas
</p>
    </div>
  </div>
</footer>
