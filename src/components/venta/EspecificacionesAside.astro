---
interface Props {
  dims: string;
  material: string;
  categoria?: string;
  whatsappUrl: string;
  incluye?: string[];
}

const {
  dims,
  material,
  categoria,
  whatsappUrl,
  incluye = [
    "Entrega en CDMX y EdoMex",
    "Asesoría sin costo",
    "Uso comercial intensivo",
    "Garantía incluida",
    "Soporte post-venta",
  ],
} = Astro.props;

const specs = [
  { label: "Dimensiones", valor: dims, icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22', align: "right" },
  { label: "Material", valor: material, icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', align: "right" },
];
---

<aside class="lg:sticky lg:top-24 flex flex-col gap-4">
  <!-- Card: especificaciones técnicas -->
  <div class="bg-surface border border-border rounded-2xl p-5">
    <p class="font-display text-[11px] font-bold uppercase tracking-widest text-primary mb-4">
      Especificaciones
    </p>
    <ul class="flex flex-col gap-3">
      {specs.map(({ label, valor, icon, align }, i) => (
        <>
          <li class:list={[
            "flex gap-3 text-sm",
            align === "right" ? "items-center justify-between" : "items-center justify-between",
          ]}>
            <span class="text-muted flex items-center gap-2">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true" set:html={`<path d="${icon}"/>`} />
              {label}
            </span>
            <strong class:list={["font-display font-bold text-text", align === "right" && "text-right"]}>
              {valor}
            </strong>
          </li>
          <li class="h-px bg-border" aria-hidden="true"></li>
        </>
      ))}
      {categoria && (
        <>
          <li class="flex items-center justify-between gap-3 text-sm">
            <span class="text-muted flex items-center gap-2">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
              Categoría
            </span>
            <strong class="font-display font-bold text-text capitalize">{categoria}</strong>
          </li>
          <li class="h-px bg-border" aria-hidden="true"></li>
        </>
      )}
      <li class="flex items-center justify-between gap-3 text-sm">
        <span class="text-muted flex items-center gap-2">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><path d="M5 8h14M5 8a2 2 0 1 0 0-4h14a2 2 0 1 0 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4"/></svg>
          Entrega
        </span>
        <strong class="font-display font-bold text-text">Coordinada</strong>
      </li>
    </ul>
  </div>

  <!-- CTA compacto -->
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center gap-2 px-5 py-3.5 bg-cta hover:bg-cta-dk text-white font-display font-bold text-sm rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.25)] hover:-translate-y-px transition-all duration-200"
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
    Solicitar información
  </a>

  <!-- Card: lo que incluye -->
  <div class="bg-white border border-border rounded-2xl p-5">
    <p class="font-display text-[11px] font-bold uppercase tracking-widest text-primary mb-4">
      Lo que incluye
    </p>
    <ul class="flex flex-col gap-2.5">
      {incluye.map((item) => (
        <li class="flex items-center gap-2.5 text-sm text-muted">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-cta-dk shrink-0" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
          {item}
        </li>
      ))}
    </ul>
  </div>
</aside>