---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CatalogHero from "../../components/shared/Hero.astro";
import VentaCard from "../../components/cards/VentaCard.astro";

const todos = await getCollection("venta");
type Categoria = NonNullable<(typeof inflables)[number]["data"]["categoria"]>;

// Ordenar alfabéticamente
const inflables = todos.sort((a, b) =>
  a.data.titulo.localeCompare(b.data.titulo, "es"),
);

// Categorías únicas — solo las que tienen inflables
const categorias = [
  "Todos",
  ...new Set(
    inflables.map((i) => i.data.categoria).filter((c): c is Categoria => !!c),
  ),
];

const whatsappUrl =
  "https://wa.me/525539385685?text=Hola%2C%20me%20interesa%20comprar%20un%20inflable%20para%20mi%20negocio.%20%C2%BFPodr%C3%ADan%20darme%20informaci%C3%B3n%3F";
---

<BaseLayout
  title="Venta de Inflables Comerciales de Uso Rudo en CDMX y Estado de México | Pequeños Momentos"
  description="Venta de inflables comerciales de uso rudo para negocios de renta, salones de fiestas y guarderías. Material certificado, garantía de fábrica en CDMX y Estado de México."
  ogImage="/og-venta.jpg"
  breadcrumbs={[{ name: "Inicio", href: "/" }, { name: "Venta de Inflables", href: "/venta-de-inflables" }]}
>
  <CatalogHero type="venta" items={inflables} whatsappUrl={whatsappUrl} />

  <!-- ── Filtros + Grid ────────────────────────────────────────── -->
  <section class="py-12 md:py-16">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <!-- Encabezado SEO mejorado -->
      <div class="mb-10 flex flex-col gap-3">
        <!-- Eyebrow -->
        <span
          class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary"
        >
          <span class="w-6 h-0.5 bg-primary rounded-full"></span>
          CDMX y Estado de México
          <span class="w-6 h-0.5 bg-primary rounded-full"></span>
        </span>

        <!-- Título -->
        <h2
          class="font-display text-2xl md:text-4xl font-extrabold text-text leading-tight"
        >
          Inflables comerciales
          <span class="text-primary"> para tu negocio</span>
        </h2>

        <!-- Descripción -->
        <p class="text-muted max-w-140 text-sm md:text-base leading-relaxed">
          Material de uso rudo para negocios de renta, salones de fiestas y
          guarderías. Entrega coordinada en CDMX y Estado de México con asesoría
          incluida.
        </p>

        <!-- Chips -->
        <ul class="flex flex-wrap gap-2 mt-1" aria-hidden="true">
          {
            [
              "✓ Uso comercial intensivo",
              "✓ Asesoría sin costo",
              "✓ Entrega en CDMX y EdoMex",
              `✓ ${inflables.length} modelos disponibles`,
            ].map((chip) => (
              <li class="text-xs font-semibold px-3 py-1 rounded-full bg-primary/10 text-primary border border-primary/20">
                {chip}
              </li>
            ))
          }
        </ul>
      </div>

      <ul
        id="catalog-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-1"
        aria-label="Catálogo de inflables en renta"
      >
        {inflables.map((item) => <VentaCard item={item} />)}
      </ul>

      <!-- Estado vacío -->
      <div
        id="empty-state"
        class="hidden flex-col items-center justify-center py-24 text-center"
      >
        <p class="text-4xl mb-4">🎈</p>
        <p class="font-display font-bold text-lg text-text mb-2">
          Sin resultados en esta categoría
        </p>
        <p class="text-sm text-muted mb-6">
          Prueba con otra categoría o contáctanos directamente
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dk text-white font-display font-bold text-sm rounded-xl transition-colors"
        >
          Solicitar información
        </a>
      </div>
    </div>
  </section>

  <!-- ── Bloque de confianza B2B ───────────────────────────────── -->
  <section class="bg-surface border-y border-border py-14">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <h2
        class="font-display text-2xl font-extrabold text-text mb-8 text-center"
      >
        ¿Por qué comprar con nosotros?
      </h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          [
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
              title: "Material comercial",
              desc: "Lona de uso rudo pensada para múltiples eventos por semana.",
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14M5 8a2 2 0 1 0 0-4h14a2 2 0 1 0 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4"/></svg>`,
              title: "Entrega coordinada",
              desc: "Entregamos en CDMX y Estado de México con agenda previa.",
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
              title: "Atención rápida",
              desc: "Respondemos en menos de 1 hora en horario de atención.",
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
              title: "Asesoría incluida",
              desc: "Te orientamos sobre qué medida y modelo conviene más para tu negocio.",
            },
          ].map(({ icon, title, desc }) => (
            <li class="flex items-start gap-3">
              <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-primary/10 text-primary">
                <Fragment set:html={icon} />
              </div>
              <div>
                <p class="font-display font-bold text-sm text-text leading-tight mb-0.5">
                  {title}
                </p>
                <p class="text-[13px] text-muted leading-relaxed">{desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── CTA final ─────────────────────────────────────────────── -->
  <section class="bg-primary py-14">
    <div class="max-w-160 mx-auto px-5 md:px-10 text-center">
      <h2
        class="font-display text-2xl md:text-3xl font-extrabold text-white mb-3"
      >
        ¿Listo para hacer crecer tu negocio?
      </h2>
      <p class="text-white/75 text-sm mb-7">
        Escríbenos por WhatsApp, cuéntanos tu proyecto y te asesoramos sin costo
        sobre qué inflable conviene más para tu modelo de negocio.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.4)] hover:-translate-y-px transition-all duration-200"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
          ></path></svg
        >
        Solicitar información por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".catalog-item");
  const countEl = document.getElementById("count-num")!;
  const emptyEl = document.getElementById("empty-state")!;
  const gridEl = document.getElementById("catalog-grid")!;

  function filter(cat: string) {
    let visible = 0;

    items.forEach((item) => {
      const match = cat === "Todos" || item.dataset.categoria === cat;
      item.style.display = match ? "" : "none";
      if (match) visible++;
    });

    countEl.textContent = String(visible);

    if (visible === 0) {
      gridEl.style.display = "none";
      emptyEl.classList.remove("hidden");
      emptyEl.classList.add("flex");
    } else {
      gridEl.style.display = "";
      emptyEl.classList.add("hidden");
      emptyEl.classList.remove("flex");
    }

    btns.forEach((btn) => {
      const isActive = btn.dataset.cat === cat;
      btn.setAttribute("aria-pressed", String(isActive));
      if (isActive) {
        btn.classList.add(
          "bg-[var(--color-primary)]",
          "border-[var(--color-primary)]",
          "text-white",
        );
        btn.classList.remove(
          "bg-white",
          "border-[var(--color-border)]",
          "text-[var(--color-muted)]",
        );
      } else {
        btn.classList.remove(
          "bg-[var(--color-primary)]",
          "border-[var(--color-primary)]",
          "text-white",
        );
        btn.classList.add(
          "bg-white",
          "border-[var(--color-border)]",
          "text-[var(--color-muted)]",
        );
      }
    });
  }

  btns.forEach((btn) => {
    btn.addEventListener("click", () => filter(btn.dataset.cat ?? "Todos"));
  });
</script>
