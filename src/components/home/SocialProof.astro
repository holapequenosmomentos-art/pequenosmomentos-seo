---
const stats = [
  { value: "+500", label: "Eventos realizados" },
  { value: "+5",   label: "Años de experiencia" },
  { value: "100%", label: "Clientes satisfechos" },
  { value: "2",    label: "Estados con cobertura" },
];

const reviews = [
  {
    name: "Alejandra M.",
    location: "Naucalpan, EdoMex",
    text: "Llegaron puntual, el castillo estaba impecable y los niños la pasaron increíble. Sin duda los volvería a contratar para la siguiente fiesta.",
    stars: 5,
    initial: "A",
  },
  {
    name: "Roberto G.",
    location: "Gustavo A. Madero, CDMX",
    text: "Excelente servicio, muy profesionales. La alberca de pelotas fue el hit de la fiesta. El proceso de cotización por WhatsApp fue muy rápido.",
    stars: 5,
    initial: "R",
  },
  {
    name: "Fernanda L.",
    location: "Tlalnepantla, EdoMex",
    text: "Muy buena atención desde el primer mensaje. El inflable llegó limpio y en perfectas condiciones. Lo recomiendo totalmente.",
    stars: 5,
    initial: "F",
  },
];

const stars = (n: number) =>
  Array.from({ length: 5 }, (_, i) => i < n ? "★" : "☆").join("");
---

<section class="bg-surface py-20 md:py-24" aria-label="Reseñas y estadísticas">
  <div class="max-w-300 mx-auto px-5 md:px-10">

    <!-- Eyebrow + título -->
    <div class="text-center mb-12">
      <p class="font-display text-[13px] font-bold uppercase tracking-widest text-primary mb-2">
        Lo que dicen nuestros clientes
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-extrabold text-text">
        Más de 500 familias nos eligen
      </h2>
    </div>

    <!-- Stats -->
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-14">
      {stats.map(({ value, label }) => (
        <li class="flex flex-col items-center text-center p-6 bg-white rounded-2xl border border-border shadow-[0_2px_16px_rgba(155,93,229,0.07)]">
          <span class="font-display text-4xl font-extrabold text-primary leading-none mb-1">
            {value}
          </span>
          <span class="text-sm text-muted">{label}</span>
        </li>
      ))}
    </ul>

    <!-- Reseñas -->
  <ul class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {reviews.map(({ name, location, text, stars: s, initial }) => (
  <li class="flex flex-col gap-4 p-6 bg-white rounded-2xl border border-border shadow-[0_2px_16px_rgba(155,93,229,0.07)]">
  <!-- Estrellas -->
<p
class="text-accent text-lg tracking-wide"
aria-label="{s} de 5 estrellas"
>
  {stars(s)}
</p>
  <!-- Texto -->
  <p class="text-sm text-muted leading-relaxed flex-1">
  "{text}"
  </p>
  <!-- Avatar + nombre -->
  <div class="flex items-center gap-3 pt-2 border-t border-border">
  <div class="flex items-center justify-center w-9 h-9 rounded-full bg-primary/15 font-display font-bold text-sm text-primary">
  {initial}
  </div>
  <div>
  <p class="font-display font-bold text-sm text-text">{name}</p>
  <p class="text-[11px] text-light">{location}</p>
  </div>
  </div>
  </li>
  ))}
  </ul>
  
  <!-- WhatsApp CTA en testimonios -->
  <div class="col-span-3 mt-8 text-center">
  <a
  href="https://wa.me/525539385685?text=Hola%2C%20quiero%20una%20cotizaci%C3%B3n%20para%20un%20inflable%20para%20mi%20evento%20infantil"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_20px_rgba(0,200,150,0.4)] hover:-translate-y-px transition-all duration-200"
  >
  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  Solicitar cotización por WhatsApp
  </a>
  </div>

  </div>
</section>