---
const metodos = [
  {
    nombre: "Tarjetas",
    desc: "Débito y crédito",
    nota: "Visa · Mastercard",
    bg: "bg-primary",
    icon: `<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>`,
  },
  {
    nombre: "Transferencia",
    desc: "Bancaria",
    nota: "Inmediato y seguro",
    bg: "bg-cta-dk",
    icon: `<rect x="3" y="10" width="18" height="9" rx="1"/><path d="M3 10 12 4l9 6"/><line x1="7" y1="13" x2="7" y2="17"/><line x1="12" y1="13" x2="12" y2="17"/><line x1="17" y1="13" x2="17" y2="17"/>`,
  },
  {
    nombre: "Efectivo",
    desc: "Al momento",
    nota: "Pago directo",
    bg: "bg-[#E0A82E]",
    icon: `<rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M6 6v0M18 18v0"/>`,
  },
  {
    nombre: "MSI",
    desc: "Pago en mensualidades",
    nota: "Fácil y cómodo",
    bg: "bg-[#3B82F6]",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M9.5 9a2.5 2.5 0 0 1 5 0c0 1.5-2.5 2-2.5 3.5M12 16h.01"/>`,
  },
];
---

<div class="mb-16">
  <div class="text-center mb-8">
    <p class="flex items-center justify-center gap-2.5 font-display text-xl font-extrabold text-text mb-1.5">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
      Formas de pago
    </p>
    <p class="text-sm text-muted">Elige la opción que más te convenga</p>
  </div>

  <ul class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    {metodos.map(({ nombre, desc, nota, bg, icon }) => (
      <li class:list={["rounded-2xl p-5 text-center text-white", bg]}>
        <span class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-white/20 mb-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icon} />
        </span>
        <p class="font-display font-bold text-sm mb-0.5">{nombre}</p>
        <p class="text-[12px] text-white/85 leading-snug">{desc}</p>
        <p class="text-[11px] text-white/65 mt-0.5">{nota}</p>
      </li>
    ))}
  </ul>

  <p class="flex items-center justify-center gap-1.5 text-[13px] text-muted mt-6">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-cta-dk shrink-0" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
    Todos los pagos son 100% seguros
  </p>
</div>