---
import { Image } from "astro:assets";

const navLinks = [
  { href: "/renta-de-inflables", label: "Renta de inflables" },
  { href: "/venta-de-inflables", label: "Venta de inflables" },
  { href: "/inflables-para-empresas", label: "Para empresas" },
  { href: "/inflables-para-escuelas", label: "Para escuelas" },
  { href: "/inflables-en-estado-de-mexico", label: "En EdoMex" },
];

const whatsappUrl =
  "https://wa.me/525539385685?text=Hola%2C%20quiero%20cotizar%20un%20inflable%20para%20mi%20evento";

const currentPath = Astro.url.pathname;

const iconWa = `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`;
---

<header
  id="site-header"
  class="fixed z-50 bg-white/55 backdrop-blur-sm border-b border-border transition-shadow duration-200 w-full"
>
  <div
    class="max-w-300 mx-auto px-5 md:px-10 flex items-center justify-between gap-8 h-20"
  >
    <!-- Logo -->
    <a href="/" aria-label="Pequeños Momentos — inicio" class="shrink-0">
      <Image
        src="/logo-sf.png"
        alt="Pequeños Momentos"
        width="140"
        height="40"
        class="h-20 w-auto"
      />
    </a>

    <!-- Nav desktop -->
    <nav aria-label="Navegación principal" class="hidden lg:block">
      <ul class="flex items-center gap-1">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "font-display text-sm font-medium px-3 py-1.5 rounded-md transition-colors duration-150",
                  currentPath.startsWith(href)
                    ? "text-primary bg-primary/8"
                    : "text-muted hover:text-primary hover:bg-primary/7",
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="flex items-center gap-3">
      <!-- CTA WhatsApp desktop -->
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden lg:inline-flex items-center gap-1.5 px-4 py-2 bg-cta hover:bg-cta-dk text-white font-display text-sm font-bold rounded-xl transition-colors duration-200 whitespace-nowrap"
        aria-label="Cotizar por WhatsApp"
      >
        <Fragment set:html={iconWa} />
        Cotizar
      </a>

      <a
        href="/contacto"
        class:list={[
          "hidden lg:inline-flex items-center gap-1.5 px-4 py-2 font-display text-sm font-bold rounded-xl transition-all duration-200 whitespace-nowrap border",
          currentPath.startsWith("/contacto")
            ? "bg-primary text-white border-primary"
            : "bg-white text-primary border-primary/30 hover:bg-primary hover:text-white hover:border-primary hover:shadow-md hover:-translate-y-0.5",
        ]}
        aria-label="Ir a la página de contacto"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4h16v16H4z" stroke="none"></path>
          <path d="M22 6 12 13 2 6"></path>
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
        </svg>
        Contacto
      </a>

      <!-- Hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col justify-center items-center gap-1.25 w-10 h-10 rounded-lg hover:bg-surface transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <span
          id="bar2"
          class="block w-5.5 h-0.5 bg-text rounded-full transition-opacity duration-250"
        ></span>
        <span
          id="bar1"
          class="block w-5.5 h-0.5 bg-text rounded-full transition-transform duration-250"
        ></span>
        <span
          id="bar3"
          class="block w-5.5 h-0.5 bg-text rounded-full transition-transform duration-250"
        ></span>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-border bg-white px-5 pb-6 pt-3"
    aria-hidden="true"
  >
    <ul class="flex flex-col gap-1">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "block font-display text-base font-medium px-2 py-3 rounded-lg border-b border-border transition-colors duration-150",
                currentPath.startsWith(href)
                  ? "text-primary bg-primary/5"
                  : "text-muted hover:text-primary",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
      <li class="mt-3">
        <a
        href="/contacto"
        class:list={[
          "flex items-center gap-1.5 px-4 py-2 font-display text-sm font-bold rounded-xl transition-all duration-200 whitespace-nowrap border",
          currentPath.startsWith("/contacto")
            ? "bg-primary text-white border-primary"
            : "bg-white text-primary border-primary/30 hover:bg-primary hover:text-white hover:border-primary hover:shadow-md hover:-translate-y-0.5",
        ]}
        aria-label="Ir a la página de contacto"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4h16v16H4z" stroke="none"></path>
          <path d="M22 6 12 13 2 6"></path>
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
        </svg>
        Contacto
      </a>
      </li>
      <li class="mt-3">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-6 py-3.5 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl transition-colors duration-200"
        >
          <Fragment set:html={iconWa} />
          Cotizar por WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const header = document.getElementById("site-header")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;

  toggle.addEventListener("click", () => {
    const isOpen = menu.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    menu.setAttribute("aria-hidden", String(!isOpen));
    bar1.style.transform = isOpen ? "translateY(7px) rotate(45deg)" : "";
    bar2.style.opacity = isOpen ? "0" : "1";
    bar3.style.transform = isOpen ? "translateY(-7px) rotate(-45deg)" : "";
  });

  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.setAttribute("aria-hidden", "true");
      toggle.setAttribute("aria-expanded", "false");
      bar1.style.transform = "";
      bar2.style.opacity = "1";
      bar3.style.transform = "";
    });
  });

  window.addEventListener(
    "scroll",
    () => {
      header.classList.toggle(
        "shadow-[0_2px_20px_rgba(155,93,229,0.12)]",
        window.scrollY > 10,
      );
    },
    { passive: true },
  );
</script>
