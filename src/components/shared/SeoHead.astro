---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown>; // JSON-LD adicional por página
}

const {
  title,
  description,
  canonical,
  ogImage = "/og-default.jpg",
  schema,
} = Astro.props;

const siteUrl   = "https://pequenosmomentos.mx";
const siteName  = "Pequeños Momentos";
const canonicalUrl = canonical ?? Astro.url.href;

// Schema LocalBusiness — se inyecta en todas las páginas
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  image: `${siteUrl}${ogImage}`,
  description:
    "Renta y venta de inflables para fiestas infantiles en CDMX y Estado de México. Entrega e instalación incluida.",
  telephone: "+525539385685",
  email: "hola.pequenosmomentos@gmail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Nicolás Romero",
    addressRegion: "Estado de México",
    addressCountry: "MX",
  },
  areaServed: [
    "Ciudad de México",
    "Nicolás Romero",
    "Naucalpan de Juárez",
    "Tlalnepantla de Baz",
    "Cuautitlán Izcalli",
    "Cuautitlán",
    "Tepotzotlán",
    "Tultepec",
    "Tultitlán",
    "Atizapán de Zaragoza",
    "Huixquilucan",
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "10:00",
      closes: "18:30",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: "09:00",
      closes: "14:00",
    },
  ],
  sameAs: [
    "https://www.instagram.com/pequenosmomentos.mx/",
    "https://www.facebook.com/pequenosmomentos.mx",
    "https://www.tiktok.com/@pequenosmomentos.mx",
  ],
};
---

<!-- Básico -->
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#9B5DE5" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Robots -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- Open Graph -->
<meta property="og:type"        content="website" />
<meta property="og:site_name"   content={siteName} />
<meta property="og:url"         content={canonicalUrl} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={`${siteUrl}${ogImage}`} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale"      content="es_MX" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

<!-- Favicon mínimo (agrega tus propios en /public) -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- JSON-LD LocalBusiness (siempre) -->
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

<!-- JSON-LD adicional de la página (FAQPage, Product, etc.) -->
{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}