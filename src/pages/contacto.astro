---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactHero from "../components/contact/ContactHero.astro";
import ContactForm from "../components/contact/ContactForm.astro";
import ContactMap from "../components/contact/ContactMap.astro";

const formspreeEndpoint = "https://formspree.io/f/xpqgpywo";
---

<BaseLayout
  title="Contacto | Renta y Venta de Inflables en CDMX y Estado de México"
  description="Solicita una cotización para renta o venta de inflables, albercas de pelotas, soft play y mobiliario infantil. Atención en Ciudad de México y Estado de México."
  ogImage="/og-contacto.jpg"
>
  <section class="relative overflow-hidden bg-surface py-26 md:py-20">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-primary/10  pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-cta/10 pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-5 md:px-10 relative">
      <ContactHero />

      <div class="grid lg:grid-cols-2 gap-1 items-stretch">
        <ContactMap />

        <div class="bg-white rounded-2xl border border-border shadow-xl p-6 md:p-5">
          <ContactForm formspreeEndpoint={formspreeEndpoint} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>