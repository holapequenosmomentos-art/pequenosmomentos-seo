---
import BaseLayout from "../../layouts/BaseLayout.astro";
import B2BHero from "../../components/shared/B2BHero.astro";

const whatsappUrl = "https://wa.me/525539385685?text=Hola%2C%20me%20interesan%20inflables%20para%20escuela.%20%C2%BFPodr%C3%ADan%20darme%20informaci%C3%B3n%3F";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cuáles son los requisitos para rentar inflables para una escuela?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Solo necesitas un espacio plano y libre de objetos punzocortantes. Nuestro equipo se encarga de la instalación, supervisión y retiro. Proporcionamos certificate de inspección y seguro de responsabilidad civil.",
      },
    },
    {
      "@type": "Question",
      name: "¿Los inflables son seguros para niños de todas las edades?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, contamos con inflables especialmente diseñados para diferentes grupos de edad, desde preescolar hasta secundaria. Todos cumplen con normas de seguridad y son inspeccionados antes de cada evento.",
      },
    },
    {
      "@type": "Question",
      name: "¿Pueden trabajar con el calendario escolar?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Por supuesto. Nos adaptamos a tus fechas, incluyendo eventos deportivos, ferias escolares, día del niño, posadas y fin de cursos. Siempre respecting los horarios escolares.",
      },
    },
    {
      "@type": "Question",
      name: "¿Ofrecen descuentos para escuelas públicas?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, tenemos tarifas especiales para instituciones educativas públicas. Contáctanos y te enviamos una cotización personalizada según tus necesidades y presupuesto.",
      },
    },
  ],
};
---

<BaseLayout
  title="Inflables para Escuelas | Renta y Venta de Juegos Inflables Educativos en CDMX y Estado de México"
  description="Inflables para eventos escolares, ferias educativas y celebraciones en escuelas. Castillos, albercas y juegos seguros para niños de todas las edades en CDMX y Estado de México."
  ogImage="/og-escuelas.jpg"
  schema={faqSchema}
  breadcrumbs={[{ name: "Inflables para Escuelas", href: "/inflables-para-escuelas" }]}
>
  <B2BHero
    eyebrow="Inflables para Escuelas"
    title="Juegos inflables para"
    titleHighlight="eventos escolares"
    description="Soluciones profesionales en inflables para escuelas que buscan actividades seguras, divertidas y memorables para sus estudiantes. Cumplimos con todos los requisitos de seguridad."
    badges={[
      { icon: "🏫", label: "Experiencia escolar" },
      { icon: "🛡️", label: "Certificación de seguridad" },
      { icon: "👶", label: "Todas las edades" },
      { icon: "📋", label: "Seguro incluido" },
    ]}
    primaryCta={{ label: "Ver catálogo", href: "/renta-de-inflables" }}
    whatsappUrl={whatsappUrl}
  />

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          ¿Por qué elegir inflables para eventos escolares?
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Los inflables son la opción perfecta para complementar actividades académicas y crear experiencias inolvidables para los estudiantes.
        </p>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Actividad segura</h3>
          <p class="text-muted text-sm leading-relaxed">Superficies acolchadas y suaves que minimizan el riesgo de lesiones incluso en caídas accidentales.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Diversión garantizada</h3>
          <p class="text-muted text-sm leading-relaxed">Los niños disfrutan durante horas mientras los docentes pueden descansar o atender otras actividades.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Inclusión</h3>
          <p class="text-muted text-sm leading-relaxed">Niños de todas las capacidades pueden participar. No se requiere habilidad especial.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Fácil programación</h3>
          <p class="text-muted text-sm leading-relaxed">Nos adaptamos al calendario escolar: días deportivos, ferias, posadas, fin de cursos y más.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Tarifas educativas</h3>
          <p class="text-muted text-sm leading-relaxed">Precios especiales para instituciones educativas públicas y privadas con paquetes personalizados.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Responsabilidad civil</h3>
          <p class="text-muted text-sm leading-relaxed">Todos nuestros equipos incluyen seguro de responsabilidad civil para su tranquilidad.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-surface border-y border-border">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          Eventos escolares más comunes
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Cada evento escolar tiene necesidades diferentes. Te ayudamos a elegir el inflable perfecto.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🏃</div>
          <h3 class="font-display font-bold text-text mb-1">Días deportivos</h3>
          <p class="text-muted text-sm">Actividades al aire libre con juegos Inflables Competition para toda la escuela.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎪</div>
          <h3 class="font-display font-bold text-text mb-1">Ferias escolares</h3>
          <p class="text-muted text-sm">Múltiples inflables simultáneos para cubrir diferentes grupos de edad.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎄</div>
          <h3 class="font-display font-bold text-text mb-1">Posadas y navideñas</h3>
          <p class="text-muted text-sm">Inflables temáticos para celebrar con los estudiantes y sus familias.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎓</div>
          <h3 class="font-display font-bold text-text mb-1">Fin de cursos</h3>
          <p class="text-muted text-sm">Cierre de ciclo escolar memorable con actividades para toda la comunidad.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">👶</div>
          <h3 class="font-display font-bold text-text mb-1">Día del niño</h3>
          <p class="text-muted text-sm">Celebración especial con los inflables favoritos de los pequeños.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎨</div>
          <h3 class="font-display font-bold text-text mb-1">Talleres y clubes</h3>
          <p class="text-muted text-sm">Actividades extracurriculares con juegos inflables didácticos.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-5 md:px-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-extrabold text-white mb-4">
        ¿Planning un evento escolar?
      </h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">
        Contáctanos y recibe una cotización personalizada en menos de 1 hora. Tenemos tarifas especiales para instituciones educativas.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.4)] hover:-translate-y-px transition-all duration-200"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        Solicitar cotización para mi escuela
      </a>
    </div>
  </section>
</BaseLayout>