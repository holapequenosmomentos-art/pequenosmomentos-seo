  { href: "https://www.facebook.com/pequenosmomentos.mx", label: "Facebook", bg: "bg-[#1877F2]", fg: "text-white", path: `<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>` },
  { href: "https://www.youtube.com/@Peque%C3%B1osMomentos-v8e", label: "YouTube", bg: "bg-[#FF0000]", fg: "text-white", path: `<path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.5 15.5v-7l6 3.5z"/>` },
  { href: "https://www.instagram.com/pequenosmomentos.mx/", label: "Instagram", bg: "bg-[#E1306C]", fg: "text-white", path: `<rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="17.3" cy="6.7" r="0.9" fill="currentColor" stroke="none"/>` },
];
---

  <ul class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-16">
  <!-- Contacto -->
  <li class="bg-surface border border-border rounded-2xl p-6">
  <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cta-dk" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  Contacto
  </p>
  <div class="flex flex-col gap-4 text-sm">
  <div>
  <p class="font-display font-bold text-text text-[13px] mb-1.5">Horarios</p>
  <p class="text-muted leading-relaxed">Lun a Vie: 10:00am – 6:30pm<br />Sáb: 9:00am – 2:00pm</p>
  </div>
  <div>
  <p class="font-display font-bold text-text text-[13px] mb-1.5">Email</p>
  <a href="mailto:hola.pequenosmomentos@gmail.com" class="text-muted hover:text-primary transition-colors break-all">
  hola.pequenosmomentos@gmail.com
  </a>
  </div>
  <div>
  <p class="font-display font-bold text-text text-[13px] mb-1.5">Teléfono</p>
  <a href="tel:+525539385685" class="text-muted hover:text-primary transition-colors">55 3938 5685</a>
  </div>
  </div>
  </li>
  
  <!-- WhatsApp CTA en footer -->
  <li class="bg-surface border border-border rounded-2xl p-6">
  <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  WhatsApp
  </p>
  <p class="text-muted leading-relaxed mb-4">Cotiza en menos de 1 hora</p>
  <a
  href="https://wa.me/525539385685?text=Hola%2C%20quiero%20una%20cotizaci%C3%B3n%20para%20un%20inflable%20para%20mi%20evento%20infantil"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-display font-bold text-sm rounded-xl shadow-[0_4px_18px_rgba(37,211,102,0.45)] transition-all duration-200 w-full"
  >
  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  Cotizar ahora
  </a>
  </li>

  <!-- Servicio -->
  <li class="bg-surface border border-border rounded-2xl p-6">
    <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Servicio
    </p>
    <div class="flex flex-col gap-4 text-sm">
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">Cobertura</p>
        <p class="text-muted leading-relaxed">CDMX y Estado de México</p>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">Especialidad</p>
        <p class="text-muted leading-relaxed">Eventos infantiles únicos</p>
      </div>
      <div>
        <p class="font-display font-bold text-text text-[13px] mb-1.5">Compromiso</p>
        <p class="text-muted leading-relaxed">Momentos inolvidables</p>
      </div>
    </div>
  </li>

  <!-- Síguenos -->
  <li class="bg-surface border border-border rounded-2xl p-6">
    <p class="flex items-center gap-2.5 font-display font-bold text-text mb-5">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cta" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Síguenos
    </p>
    <p class="text-sm text-muted leading-relaxed mb-5">¡Mira nuestros eventos en acción!</p>
    <div class="flex gap-2.5 mb-4">
      {redes.map(({ href, label, bg, fg, path }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          class:list={["flex items-center justify-center w-10 h-10 rounded-full transition-transform duration-150 hover:-translate-y-0.5", bg, fg]}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={path} />
        </a>
      ))}
    </div>
    <p class="flex items-center gap-1.5 text-[12px] text-light bg-white rounded-lg px-3 py-2 border border-border">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      Contenido divertido y tips para fiestas
    </p>
  </li>
</ul>