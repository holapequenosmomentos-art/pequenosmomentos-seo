---
import { Image } from "astro:assets";

const whatsappUrl =
  "https://wa.me/525539385685?text=Hola%2C%20quiero%20cotizar%20un%20inflable%20para%20mi%20evento";

const badges = [
  { icon: "⭐", text: "+500 eventos realizados" },
  { icon: "📍", text: "CDMX y Estado de México" },
  { icon: "🚚", text: "Entrega e instalación incluida" },
];

const collageImages = [
  {
    src: "/inflables/venta/alberca-pelotas.webp",
    alt: "Castillo inflable rentado en CDMX",
  },
  {
    src: "/inflables/venta/castillo-alberca.webp",
    alt: "Alberca de pelotas inflable para eventos infantiles",
  },
  {
    src: "/inflables/venta/alberca-resbaladilla.webp",
    alt: "Tobogán inflable para fiestas infantiles",
  },
  {
    src: "/inflables/renta/flores.webp",
    alt: "Bubble house inflable con brincolín",
  },
  {
    src: "/inflables/renta/bumper-cars.webp",
    alt: "Pista inflable para eventos infantiles",
  },
];
---

<section
  class="relative bg-surface overflow-hidden min-h-screen flex items-center"
>
  <!-- Orbe decorativo fondo -->
  <div
    class="absolute -top-32 -right-20 w-125 h-125 bg-primary/10 rounded-full pointer-events-none"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -bottom-32 -left-40 w-125 h-125 bg-primary/10 rounded-full pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div
    class="max-w-7xl mx-auto px-5 md:px-10 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-1 items-center"
  >
    <!-- Copy -->
    <div>
      <p
        class="font-display text-[13px] font-bold uppercase tracking-widest text-primary mb-4"
      >
        Fiestas infantiles · CDMX y Estado de México
      </p>

      <h1
        class="font-display text-4xl md:text-5xl lg:text-[3.25rem] font-extrabold leading-[1.1] text-text mb-5"
      >
        Renta de inflables
        <span
          class="block text-primary underline decoration-accent decoration-4 underline-offset-[6px]"
        >
          para fiestas
        </span>
        infantiles
      </h1>

      <p class="text-base md:text-lg text-muted leading-relaxed max-w-120 mb-7">
        Castillos, albercas de pelotas, toboganes y más. Entrega, instalación y
        retiro incluidos en toda la Ciudad de México y Estado de México.
      </p>

      <!-- Badges de confianza -->
      <ul class="flex flex-wrap gap-2 mb-8" aria-label="Por qué elegirnos">
        {
          badges.map(({ icon, text }) => (
            <li class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-white border border-border rounded-full text-[13px] font-medium text-muted shadow-[0_2px_16px_rgba(155,93,229,0.08)] whitespace-nowrap">
              <span aria-hidden="true">{icon}</span>
              {text}
            </li>
          ))
        }
      </ul>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="/renta-de-inflables"
          class="md:inline-flex hidden items-center justify-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.3)] hover:-translate-y-px transition-all duration-200 whitespace-nowrap"
        >
          Ver inflables en renta
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="md:inline-flex hidden items-center justify-center gap-2 px-8 py-4 bg-transparent border-2 border-primary text-primary hover:bg-primary hover:text-white font-display font-bold text-base rounded-xl transition-all duration-200 whitespace-nowrap"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
            ></path></svg
          >
          Cotizar por WhatsApp
        </a>
      </div>
    </div>

    <!-- Collage de burbujas -->
    <div
      class="relative order-first lg:order-last h-85 sm:h-105 lg:h-120 flex items-center justify-center"
    >
      <!-- Burbuja decorativa de fondo -->
      <div
        class="absolute w-[90%] h-[90%] rounded-full bg-primary/5 blur-2xl pointer-events-none"
        aria-hidden="true"
      >
      </div>

      <!-- Burbuja 1 - XL, centro -->
      <div
        class="absolute top-[15%] left-[20%] w-[50%] aspect-square rounded-full overflow-hidden border-[5px] border-white shadow-[0_16px_40px_rgba(155,93,229,0.22)] z-30"
      >
        <Image
          src={collageImages[0].src}
          alt={collageImages[0].alt}
          width="280"
          height="280"
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Burbuja 2 - grande, arriba derecha -->
      <div
        class="absolute top-[8%] right-[4%] w-[36%] aspect-square rounded-full overflow-hidden border-[5px] border-white shadow-[0_12px_32px_rgba(155,93,229,0.18)] z-20"
      >
        <Image
          src={collageImages[1].src}
          alt={collageImages[1].alt}
          width="220"
          height="220"
          loading="lazy"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Burbuja 3 - mediana, abajo izquierda -->
      <div
        class="absolute bottom-[5%] left-[10%] w-[32%] aspect-square rounded-full overflow-hidden border-[5px] border-white shadow-[0_12px_32px_rgba(155,93,229,0.18)] z-20"
      >
        <Image
          src={collageImages[2].src}
          alt={collageImages[2].alt}
          width="230"
          height="230"
          loading="lazy"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Burbuja 4 - mediana-chica, centro derecha -->
      <div
        class="absolute top-[38%] right-[5%] w-[27%] aspect-square rounded-full overflow-hidden border-[5px] border-white shadow-[0_10px_28px_rgba(155,93,229,0.16)] z-25"
      >
        <Image
          src={collageImages[3].src}
          alt={collageImages[3].alt}
          width="180"
          height="180"
          loading="lazy"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Burbuja 5 - chica, abajo centro-derecha -->
      <div
        class="absolute bottom-[2%] right-[18%] w-[43%] aspect-square rounded-full overflow-hidden border-[5px] border-white shadow-[0_10px_28px_rgba(155,93,229,0.16)] z-35"
      >
        <Image
          src={collageImages[4].src}
          alt={collageImages[4].alt}
          width="170"
          height="170"
          loading="lazy"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Sticker disponible -->
      <div
        class="absolute -bottom-2 left-[8%] inline-flex items-center gap-2 px-3.5 py-2 bg-white rounded-full font-display text-[13px] font-bold text-text shadow-[0_4px_20px_rgba(0,0,0,0.12)] z-40"
        aria-hidden="true"
      >
        <span class="w-2 h-2 rounded-full bg-cta animate-pulse-dot"></span>
        Disponible hoy
      </div>
    </div>
  </div>

  <!-- Corte diagonal inferior -->
  <div
    class="absolute bottom-0 left-0 right-0 h-16 bg-white [clip-path:polygon(0_100%,100%_0,100%_100%)]"
    aria-hidden="true"
  >
  </div>
</section>
