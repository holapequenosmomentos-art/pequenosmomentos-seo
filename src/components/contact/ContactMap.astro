---
const direccion = "Calle Dolores s/n, Local 10, Visitación, 54890 Melchor Ocampo, Méx.";
const mapsEmbedSrc =
  "https://www.google.com/maps?q=Calle+Dolores+s/n+Local+10,+Visitaci%C3%B3n,+54890+Melchor+Ocampo,+M%C3%A9x.&output=embed";
const mapsLink =
  "https://www.google.com/maps/search/?api=1&query=Calle+Dolores+s%2Fn+Local+10%2C+Visitaci%C3%B3n%2C+54890+Melchor+Ocampo%2C+M%C3%A9x.";
---

<div class="relative rounded-2xl overflow-hidden border border-border h-full min-h-[420px]">
  <iframe
    src={mapsEmbedSrc}
    width="100%"
    height="100%"
    style="border:0; position:absolute; inset:0;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Ubicación de Pequeños Momentos"
  />

  <!-- Card flotante con dirección y contacto -->
  <div class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-sm border-t border-border p-4 md:p-5">
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <p class="font-display text-[11px] font-bold uppercase tracking-wide text-primary mb-1">Contacto</p>
        <a href="mailto:hola.pequenosmomentos@gmail.com" class="text-[13px] text-text hover:text-primary transition-colors flex items-center gap-2 mb-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          hola.pequenosmomentos@gmail.com
        </a>
        <a href="tel:+525539385685" class="text-[13px] text-text hover:text-primary transition-colors flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          55 3938 5685
        </a>
      </div>
    </div>
    <a
      href={mapsLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-[12px] font-display font-bold text-primary hover:underline mt-3"
    >
      Cómo llegar
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>