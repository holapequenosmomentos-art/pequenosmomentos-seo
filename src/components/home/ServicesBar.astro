---
const items = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14M5 8a2 2 0 1 0 0-4h14a2 2 0 1 0 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4"/></svg>`,
    title: "Entrega e instalación",
    desc: "Incluida en CDMX y EdoMex",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Inflables certificados",
    desc: "Material resistente y seguro",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: "Puntualidad garantizada",
    desc: "Llegamos antes de tu evento",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Atención personalizada",
    desc: "Respondemos en menos de 1 hora",
  },
];
---

<section class="bg-white py-20" aria-label="Por qué elegirnos">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10">
    <ul class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4">
      {items.map(({ icon, title, desc }) => (
        <li class="flex items-start gap-3 lg:justify-center">
          <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
            <Fragment set:html={icon} />
          </div>
          <div>
            <p class="font-display font-700 text-sm font-bold text-[var(--color-text)] leading-tight">{title}</p>
            <p class="text-[13px] text-[var(--color-muted)] mt-0.5">{desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>