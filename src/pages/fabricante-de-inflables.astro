---
import BaseLayout from "../../layouts/BaseLayout.astro";
import B2BHero from "../../components/shared/B2BHero.astro";

const whatsappUrl = "https://wa.me/525539385685?text=Hola%2C%20me%20interesa%20comprar%20inflables%20para%20mi%20negocio.%20%C2%BFSon%20fabricantes%20directos%3F";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Son fabricantes directos de inflables?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, somos fabricantes con años de experiencia en la elaboración de inflables comerciales. Esto nos permite ofrecer precios competitivos, personalización completa y control de calidad en cada producto.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué tipo de material utilizan en sus inflables?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Utilizamos lona de alta durabilidad certificada para uso comercial intensivo. Todos nuestros productos cuentan con costuras reforzadas, doble costura en áreas de alto estrés y materiales resistentes a rayos UV.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuánto dura un inflable comercial?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Con mantenimiento adecuado y uso normal, nuestros inflables comerciales pueden durar entre 3 y 7 años dependiendo del modelo y la intensidad de uso. Ofrecemos guía de mantenimiento con cada compra.",
      },
    },
    {
      "@type": "Question",
      name: "¿Ofrecen garantía en sus productos?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, todos nuestros inflables incluyen garantía de fábrica que cubre defectos de manufacture. La garantía varía según el modelo y el tipo de uso. Consulta los términos específicos con nuestro equipo.",
      },
    },
    {
      "@type": "Question",
      name: "¿Pueden personalizar colores y diseños?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Por supuesto. Ofrecemos personalización completa: colores, logotipos, dimensiones y diseños especiales. Si necesitas un inflable con medidas o características específicas, contáctanos y lo cotizamos.",
      },
    },
  ],
};
---

<BaseLayout
  title="Fabricante de Inflables | Venta de Inflables Comerciales de Uso Rudo en CDMX y Estado de México"
  description="Fabricante directo de inflables comerciales. Venta de castillos, albercas y toboganes de uso rudo para negocios de renta. Calidad garantizada, precios de fábrica en CDMX y EdoMex."
  ogImage="/og-fabricante.jpg"
  schema={faqSchema}
  breadcrumbs={[{ name: "Fabricante de Inflables", href: "/fabricante-de-inflables" }]}
>
  <B2BHero
    eyebrow="Fabricante de Inflables"
    title="Fabricación profesional de"
    titleHighlight="inflables comerciales"
    description="Somos fabricantes directos con años de experiencia.-ofrecemos inflables de uso rudo para negocios de renta, salones de eventos y empresas que buscan calidad, durabilidad y precios de fábrica."
    badges={[
      { icon: "🏭", label: "Fabricación propia" },
      { icon: "💪", label: "Material de uso rudo" },
      { icon: "🎨", label: "Personalización completa" },
      { icon: "🛡️", label: "Garantía de fábrica" },
    ]}
    primaryCta={{ label: "Ver catálogo de venta", href: "/venta-de-inflables" }}
    whatsappUrl={whatsappUrl}
  />

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          ¿Por qué comprar directo del fabricante?
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Al comprar directamente del fabricante obtienes beneficios que no encontrarás en distribuidores o importadores.
        </p>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Precios de fábrica</h3>
          <p class="text-muted text-sm leading-relaxed">Eliminamos intermediarios para ofrecerte los mejores precios directamente del fabricante.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Personalización total</h3>
          <p class="text-muted text-sm leading-relaxed">Puedes elegir colores, medidas, logotipos y características especiales sin costo adicional oculto.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Calidad controlada</h3>
          <p class="text-muted text-sm leading-relaxed">Control de calidad en cada etapa del proceso de manufacture para garantizar productos superiores.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Entregas puntuales</h3>
          <p class="text-muted text-sm leading-relaxed">Producción eficiente que cumple con los tiempos de entrega comprometidos.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Soporte técnico</h3>
          <p class="text-muted text-sm leading-relaxed">Te asesoramos sobre el mantenimiento, reparación y cuidado de tu inflable.</p>
        </li>

        <li class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h3 class="font-display font-bold text-text mb-2">Refacciones disponibles</h3>
          <p class="text-muted text-sm leading-relaxed">Contamos con refacciones y reparaciones para que tu inflable siempre esté operational.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-surface border-y border-border">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text mb-3">
          Nuestros productos
        </h2>
        <p class="text-muted max-w-2xl mx-auto">
          Inflables diseñados para uso comercial intensivo. Ideales para negocios de renta, salones de eventos y empresas.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🏰</div>
          <h3 class="font-display font-bold text-text mb-1">Castillos inflables</h3>
          <p class="text-muted text-sm">El clásico infaltable. Variedad de tamaños y diseños para todo tipo de eventos.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🎢</div>
          <h3 class="font-display font-bold text-text mb-1">Toboganes</h3>
          <p class="text-muted text-sm">Desde moderados hasta gigantes. Diseños que generan muchas sesiones de diversión.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🏊</div>
          <h3 class="font-display font-bold text-text mb-1">Albercas de pelotas</h3>
          <p class="text-muted text-sm">Perfectas para los más pequeños. Superficies suaves y seguras.</p>
        </li>
        <li class="bg-white rounded-2xl p-5 border border-border">
          <div class="text-3xl mb-3">🏎️</div>
          <h3 class="font-display font-bold text-text mb-1">Pistas de obstáculos</h3>
          <p class="text-muted text-sm">El favorito de los eventos corporativos. Competition y diversión garantizada.</p>
        </li>
      </ul>

      <div class="text-center mt-8">
        <a href="/venta-de-inflables" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dk text-white font-display font-bold text-sm rounded-xl transition-colors">
          Ver todos los modelos en venta
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-5 md:px-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-extrabold text-white mb-4">
        ¿Quieres comprar inflables directo del fabricante?
      </h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">
        Contáctanos y recibe asesoría personalizada sobre qué modelo conviene más para tu negocio. Sin compromiso.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta hover:bg-cta-dk text-white font-display font-bold text-base rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.4)] hover:-translate-y-px transition-all duration-200"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        Solicitar información
      </a>
    </div>
  </section>
</BaseLayout>