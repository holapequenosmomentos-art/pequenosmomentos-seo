---
// Barra fija de redes sociales, centrada verticalmente a la izquierda.
// Oculta en móvil (md:flex) — en pantallas pequeñas solo se muestra WhatsApp.

const redes = [
  {
    nombre: "Instagram",
    url: "https://www.instagram.com/pequenosmomentos.mx/",
    bg: "bg-white",
    fg: "text-[#E1306C]",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    nombre: "Facebook",
    url: "https://www.facebook.com/pequenosmomentos.mx",
    bg: "bg-white",
    fg: "text-[#1877F2]",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>`,
  },
  {
    nombre: "YouTube",
    url: "https://www.youtube.com/@Peque%C3%B1osMomentos-v8e",
    bg: "bg-white",
    fg: "text-[#FF0000]",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.5 15.5v-7l6 3.5z"/></svg>`,
  },
  {
    nombre: "TikTok",
    url: "https://www.tiktok.com/@pequenosmomentos.mx",
    bg: "bg-white",
    fg: "text-text",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82s.51.5 0 0A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z"/></svg>`,
  },
];
---

<nav
  aria-label="Redes sociales"
  class="hidden md:flex fixed left-4 top-1/2 -translate-y-1/2 z-40 flex-col gap-3"
>
  {redes.map(({ nombre, url, bg, fg, icon }) => (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={nombre}
      class:list={[
        "flex items-center justify-center w-11 h-11 rounded-full shadow-[0_2px_10px_rgba(0,0,0,0.12)] border border-border transition-all duration-200 hover:-translate-x-0.5 hover:shadow-[0_4px_16px_rgba(0,0,0,0.16)]",
        bg,
        fg,
      ]}
      set:html={icon}
    />
  ))}
</nav>