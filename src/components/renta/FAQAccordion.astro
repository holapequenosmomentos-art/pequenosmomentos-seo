---
interface Faq {
  pregunta: string;
  respuesta: string;
}

interface Props {
  faqs: Faq[];
  whatsappUrl?: string;
  withSidebar?: boolean;
}

const { faqs, whatsappUrl, withSidebar = false } = Astro.props;
---

{faqs.length > 0 && (
  <section class="py-16 md:py-20">
    <div class="max-w-300 mx-auto px-5 md:px-10">
      <div class:list={[withSidebar ? "grid md:grid-cols-[280px_1fr] gap-10 md:gap-16 items-start" : ""]}>
        {withSidebar && (
          <div class="md:sticky md:top-24 flex flex-col gap-3">
            <p class="font-display text-[13px] font-bold uppercase tracking-widest text-primary">
              Resolvemos tus dudas
            </p>
            <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text leading-tight">
              Preguntas frecuentes
            </h2>
            <p class="text-sm text-muted leading-relaxed">
              ¿Algo más? Escríbenos y respondemos en minutos.
            </p>
            {whatsappUrl && (
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-white hover:bg-surface border-2 border-primary text-primary font-display font-bold text-sm rounded-xl transition-all duration-200 w-fit mt-1"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                Preguntar por WhatsApp
              </a>
            )}
          </div>
        )}

        <ul class="flex flex-col gap-3" id="faq-list">
          {faqs.map(({ pregunta, respuesta }, i) => (
            <li class="bg-white border border-border rounded-2xl overflow-hidden transition-all duration-150 hover:border-primary/40">
              <button
                class="faq-btn w-full flex items-center justify-between gap-4 px-5 py-4 text-left font-display font-bold text-sm text-text hover:text-primary transition-colors"
                aria-expanded="false"
                data-index={i}
              >
                {pregunta}
                <svg class="faq-icon shrink-0 transition-transform duration-200 text-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="faq-body hidden px-5 pb-4">
                <p class="text-sm text-muted leading-relaxed">{respuesta}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
)}

<script>
  document.querySelectorAll<HTMLButtonElement>(".faq-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const body = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector(".faq-icon") as HTMLElement;
      const isOpen = btn.getAttribute("aria-expanded") === "true";

      document.querySelectorAll<HTMLButtonElement>(".faq-btn").forEach((b) => {
        if (b !== btn) {
          b.setAttribute("aria-expanded", "false");
          (b.nextElementSibling as HTMLElement).classList.add("hidden");
          (b.querySelector(".faq-icon") as HTMLElement).style.transform = "";
        }
      });

      btn.setAttribute("aria-expanded", String(!isOpen));
      body.classList.toggle("hidden", isOpen);
      icon.style.transform = isOpen ? "" : "rotate(180deg)";
    });
  });
</script>