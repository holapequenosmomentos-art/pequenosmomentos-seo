---
import { Image } from 'astro:assets';

interface Props {
  titulo: string;
  shortTitle: string;
  description: string;

  duration: string;
  categoria: string;
  disponibilidad: boolean;
  video?: string;
  imageBanner?: string;
  whatsappUrl: string;
}

const {
  titulo,
  shortTitle,
  description,

  duration,
  categoria,
  disponibilidad,
  video,
  imageBanner,
  whatsappUrl,
} = Astro.props;

const isVideo = (src: string) =>
  src.startsWith("/") || src.endsWith(".mp4") || src.endsWith(".webm");

const specs = [
  {
    label: duration,
    icon: 'M12 6v6l4 2"/><circle cx="12" cy="12" r="10',
  },
  {
    label: "Entrega incluida",
    icon: 'M5 8h14M5 8a2 2 0 1 0 0-4h14a2 2 0 1 0 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4',
  },
  {
    label: "Instalación incluida",
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
];
---

<section class="relative overflow-hidden bg-surface pt-10 pb-16 md:pt-14 md:pb-20 h-screen flex items-center">
  <div class="pointer-events-none absolute -top-24 -right-32 w-130 h-130 rounded-full bg-primary/10" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-32 w-130 h-130 rounded-full bg-primary/10" aria-hidden="true"></div>

  <div class="max-w-300 mx-auto px-5 md:px-10 relative w-full">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-2 text-[13px] text-muted flex-wrap">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li aria-hidden="true"><span class="text-light">/</span></li>
        <li><a href="/renta-de-inflables" class="hover:text-primary transition-colors">Renta de inflables</a></li>
        <li aria-hidden="true"><span class="text-light">/</span></li>
        <li class="text-text font-medium truncate max-w-45">{shortTitle}</li>
      </ol>
    </nav>

    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
      <!-- COLUMNA INFO -->
      <div>
        <p class="font-display text-[13px] font-bold uppercase tracking-widest text-primary mb-3">
          Renta de inflable · CDMX y Estado de México
        </p>

        <h1 class="font-display text-4xl md:text-5xl font-extrabold text-text leading-[1.1] mb-5">
          {titulo}
        </h1>

        <p class="text-muted text-base leading-relaxed mb-6 max-w-115">
          {description}
        </p>

        <ul class="flex flex-wrap gap-2 mb-7">
          {specs.map(({ label, icon }) => (
            <li class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-white rounded-full text-[13px] font-display font-semibold text-text shadow-sm border border-border">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true" set:html={`<path d="${icon}"/>`} />
              {label}
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-3 mb-5">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-cta hover:bg-cta-dk text-white font-display font-bold text-sm rounded-xl shadow-[0_4px_14px_rgba(0,200,150,0.3)] hover:-translate-y-px transition-all duration-200"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            Cotizar por WhatsApp
          </a>
          <a
            href="/renta-de-inflables"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-white hover:bg-surface border-2 border-primary text-primary font-display font-bold text-sm rounded-xl transition-all duration-200"
          >
            Ver más inflables
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <p class="text-[12px] text-light">Sin costo · Respondemos en menos de 1 hora</p>
      </div>

      <!-- COLUMNA MEDIA -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden ring-4 ring-white shadow-[0_8px_40px_rgba(155,93,229,0.15)]">
          {video && isVideo(video) ? (
            <video
              src={video}
              poster={imageBanner}
              controls
              playsinline
              preload="metadata"
              class="w-full aspect-4/3 object-cover"
              aria-label={`Video de ${shortTitle}`}
            />
          ) : video ? (
            <iframe
              src={video.replace("watch?v=", "embed/")}
              title={`Video de ${shortTitle}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full aspect-4/3 border-0"
            />
          ) : imageBanner ? (
            <Image
              src={imageBanner}
              alt={titulo}
              width="700"
              height="525"
              loading="eager"
              fetchpriority="high"
              class="w-full aspect-4/3 object-cover"
            />
          ) : null}

          <span class="absolute top-4 left-4 inline-flex items-center gap-1.5 px-3.5 py-2 bg-white/90 backdrop-blur-sm rounded-full text-[13px] font-display font-bold text-primary shadow-sm border border-border">
            {categoria}
          </span>

          <span
            class:list={[
              "absolute top-4 right-4 inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-[13px] font-display font-bold shadow-md",
              disponibilidad ? "bg-white text-text" : "bg-white/80 text-light",
            ]}
          >
            <span class:list={["w-2 h-2 rounded-full", disponibilidad ? "bg-cta" : "bg-light"]}></span>
            {disponibilidad ? "Disponible ahora" : "No disponible"}
          </span>
        </div>
      </div>
    </div>
  </div>
</section>