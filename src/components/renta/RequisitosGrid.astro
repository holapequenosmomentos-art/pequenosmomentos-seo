---
interface Props {
  requisitos: string[];
}

const { requisitos } = Astro.props;
---

{requisitos.length > 0 && (
  <section class="relative overflow-hidden bg-surface border-y border-border py-14 md:py-16">
    <div class="pointer-events-none absolute -top-20 -right-20 w-80 h-80 rounded-full bg-primary/10" aria-hidden="true"></div>

    <div class="max-w-300 mx-auto px-5 md:px-10 relative">
      <div class="mb-8">
        <p class="font-display text-[13px] font-bold uppercase tracking-widest text-primary mb-2">
          Antes de rentar
        </p>
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-text">
          Requisitos de instalación
        </h2>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-195">
        {requisitos.map((req, i) => (
          <li class="inline-flex items-start gap-3 px-4 py-4 bg-white rounded-2xl border border-border shadow-sm">
            <span class="font-display font-extrabold text-2xl text-primary/20 leading-none mt-0.5 min-w-8">
              {String(i + 1).padStart(2, "0")}
            </span>
            <p class="text-sm text-muted leading-relaxed mt-1">{req}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}